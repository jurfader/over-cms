# =============================================================================
# OverCMS — Environment Variables
# Skopiuj ten plik do .env i uzupełnij wartości
# =============================================================================

# --- DATABASE ---
DATABASE_URL=postgresql://overcms:password@localhost:5432/overcms
DATABASE_URL_TEST=postgresql://overcms:password@localhost:5432/overcms_test

# --- REDIS ---
REDIS_URL=redis://localhost:6379

# --- AUTH ---
BETTER_AUTH_SECRET=zmien-na-losowy-64-znakowy-string
BETTER_AUTH_URL=http://localhost:3001

# --- STORAGE (S3-compatible / Cloudflare R2 / MinIO lokalnie) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=overcms
S3_PUBLIC_URL=http://localhost:9000/overcms

# --- API ---
API_PORT=3001
API_URL=http://localhost:3001
ADMIN_URL=http://localhost:3000
ADMIN_CORS_ORIGINS=http://localhost:3000
WEB_URL=http://localhost:3003

# --- LICENSE SERVER ---
LICENSE_PORT=3002
LICENSE_SERVER_URL=http://localhost:3002
LICENSE_ADMIN_SECRET=zmien-na-losowy-admin-secret
# Opcjonalnie osobna baza dla license server (domyślnie używa DATABASE_URL):
# LICENSE_DATABASE_URL=postgresql://overcms:password@localhost:5432/overcms_licenses

# --- EMAIL (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_DOMAIN=twojadomena.pl
EMAIL_FROM=noreply@twojadomena.pl

# --- STRIPE ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# --- APP ---
NODE_ENV=development

# --- PRODUCTION: DOCKER & DOMAINS ---
# Domeny dla Traefik (docker-compose.prod.yml)
API_DOMAIN=api.overcms.pl
ADMIN_DOMAIN=admin.overcms.pl
LICENSE_DOMAIN=license.overcms.pl
PORTAL_DOMAIN=overcms.pl

# Portal publiczny
PORTAL_URL=http://localhost:3004
NEXT_PUBLIC_LICENSE_URL=http://localhost:3002

# Stripe — ceny produktów (z Stripe Dashboard)
STRIPE_PRICE_SOLO=price_xxxxxxxxxxxxx
STRIPE_PRICE_AGENCY=price_xxxxxxxxxxxxx

# Let's Encrypt — adres email do certyfikatów SSL
ACME_EMAIL=admin@overcms.pl

# Redis hasło w produkcji
REDIS_PASSWORD=zmien-na-losowe-haslo-redis

# Postgres hasła produkcyjne
POSTGRES_USER=overcms
POSTGRES_PASSWORD=zmien-na-silne-haslo-postgres
POSTGRES_DB=overcms

# MinIO klucze produkcyjne
MINIO_ROOT_USER=overcms-minio
MINIO_ROOT_PASSWORD=zmien-na-silne-haslo-minio
