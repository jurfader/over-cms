# =============================================================================
# OverCMS — Environment Variables
# Skopiuj ten plik do .env i uzupełnij wartości
# =============================================================================

# --- DATABASE ---
DATABASE_URL=postgresql://overcms:password@localhost:5432/overcms
DATABASE_URL_TEST=postgresql://overcms:password@localhost:5432/overcms_test

# --- REDIS ---
REDIS_URL=redis://localhost:6379

# --- AUTH ---
BETTER_AUTH_SECRET=zmien-na-losowy-64-znakowy-string
BETTER_AUTH_URL=http://localhost:3001

# --- STORAGE (S3-compatible / Cloudflare R2 / MinIO lokalnie) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=overcms
S3_PUBLIC_URL=http://localhost:9000/overcms

# --- API ---
API_PORT=3001
API_URL=http://localhost:3001
ADMIN_URL=http://localhost:3000
ADMIN_CORS_ORIGINS=http://localhost:3000

# --- LICENSE SERVER ---
LICENSE_SERVER_PORT=3002
LICENSE_SERVER_URL=http://localhost:3002
LICENSE_SERVER_SECRET=zmien-na-losowy-secret

# --- EMAIL (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@twojadomena.pl

# --- STRIPE ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# --- APP ---
NODE_ENV=development
